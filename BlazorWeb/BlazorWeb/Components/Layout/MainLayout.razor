@inherits LayoutComponentBase

<AuthorizeView>
    <Authorize>
        <div class="page">
            <div class="sidebar">
                <NavMenu/>
            </div>
        
            <main>
                <div class="top-row px-4">
                    <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
                </div>
        
                <article class="content px-4">
                    @Body
                </article>
            </main>
        </div>
    </Authorize>
    <NotAuthorize>
        <div class="container mt-12 text-center">
            <div class="alert alert-danger inline-block">
                <h4>Chưa đăng nhập. Phải <a class="btn btn-secondary" href="/Admin/Login">Đăng nhập</a></h4>
            </div>
        </div>
    </NotAuthorize>
</AuthorizeView>