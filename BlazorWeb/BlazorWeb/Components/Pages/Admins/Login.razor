@page "/Admin/Login"
@using Microsoft.AspNetCore.Authorization
@using BlazorWeb.Components.Layout
@using BlazorWeb.Models
@using BlazorWeb.Services.Admins
@using Microsoft.AspNetCore.Components.Authorization
@using BlazorWeb.Components.Authentication
@attribute [AllowAnonymous]
@layout LoginLayout
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer
<h3>Login</h3>

<EditForm Model="_admin" FormName="AdminLoginForm" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator/>
    <div class="form-group">
        <label>Email: </label>
        <InputText @bind-Value="_admin.Email"/>
    </div>
    <div class="form-group">
        <label>Password: </label>
        <InputText type="password" @bind-Value="_admin.Password"/>
    </div>
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Login</button>
    </div>
</EditForm>

@code {
    private Admin _admin = new Admin();
    [Inject] NavigationManager _navigationManager { get; set; }

    private async Task HandleLogin()
    {
        bool isValid = await AuthService.ValidateAdminAuthAsync(_admin.Email, _admin.Password);

        if (isValid)
        {
            var adminAuthStateProvider = (AdminAuthStateProvider)AuthStateProvider;
            await adminAuthStateProvider.MarkAdminAsAuthenticatedAsync(_admin.Email);
            _navigationManager.NavigateTo("/Categories", true);
        }
    }
}